# ============================
# CommunicationServer 配置
# ============================

# LLM 配置（必填）
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=          # 可选，OpenAI 兼容服务地址
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=***

# 服务配置
COMM_HOST=0.0.0.0
COMM_PORT=8001
COMM_DEBUG=false

# 对话配置
COMM_MAX_HISTORY_TURNS=20
COMM_SYSTEM_PROMPT=你是一个名叫 Bumi 的人形机器人助手，性格友好、乐于助人。用中文回答，简洁自然，2-3 句话以内。

# ============================
# robot-agent 配置
# ============================

# 机器人标识
ROBOT_ID=bumi-01
COMM_SERVER_URL=ws://localhost:8001/ws/chat

# STT 语音识别 (openai / azure)
STT_PROVIDER=openai
STT_MODEL=whisper-1
STT_LANGUAGE=zh

# TTS 语音合成 (edge=免费 / openai)
TTS_PROVIDER=edge
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_SPEED=+0%

# 唤醒词（可选，暂未实现）
WAKE_WORD=
