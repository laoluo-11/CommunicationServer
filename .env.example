# CommunicationServer 环境变量配置
# 使用时复制为 .env 并填入实际值

# LLM 配置（必填）
LLM_API_KEY=sk-your-api-key-here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=          # 可选，OpenAI 兼容服务的地址（如 vLLM/Ollama）
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# 服务配置
COMM_HOST=0.0.0.0
COMM_PORT=8001
COMM_DEBUG=false

# 对话配置
COMM_MAX_HISTORY_TURNS=20
COMM_SYSTEM_PROMPT=你是一个名叫 Bumi 的人形机器人助手，性格友好、乐于助人。用中文回答，简洁自然，2-3 句话以内。
